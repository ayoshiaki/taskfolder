#!/usr/bin/env python3

import argparse
import subprocess
import os
import json
import re
import platform
import logging
import webbrowser
from datetime import datetime
from pathlib import Path
from typing import Optional, Dict, Any, List

# Logging configuration
logging.basicConfig(level=logging.INFO, format="[%(levelname)s] %(message)s")

# Configurable directories via environment variables
HOME = Path.home()
TODO_DIR = Path(os.getenv("TASKFOLDER_TODO_DIR", str(HOME / "work" / "todo")))
ARCHIVE_DIR = Path(os.getenv("TASKFOLDER_ARCHIVE_DIR", str(HOME / "work" / "archive")))

# Regex pattern to identify folder paths in annotations
FOLDER_PATH_PATTERN = re.compile(r"(/[^\s:]+/\d{8}-[0-9a-fA-F]{8})")
FOLDER_NAME_PATTERN = re.compile(r"[0-9]{8}-[0-9a-fA-F]{8}")

# Regex pattern to identify URLs in annotations
URL_PATTERN = re.compile(r"https?://[^\s]+")


# Compatible with Taskwarrior 2.x and 3.x
def load_task_info(number: str) -> Optional[Dict[str, Any]]:
    """Loads task information from Taskwarrior."""
    try:
        output = subprocess.check_output(["task", number, "export"], text=True)
        tasks = json.loads(output)
        if isinstance(tasks, list) and tasks:
            return tasks[0]
        logging.error(f"Task {number} not found or export returned empty.")
        return None
    except subprocess.CalledProcessError as e:
        logging.error(f"Failed to run 'task {number} export': {e}")
        return None
    except json.JSONDecodeError as e:
        logging.error(f"Failed to parse JSON output: {e}")
        return None


def _extract_folder_from_task(task: Dict[str, Any]) -> Optional[Path]:
    """Extracts the folder path from task annotations."""
    annotations = task.get("annotations", [])
    for ann in annotations:
        match = FOLDER_PATH_PATTERN.search(ann.get("description", ""))
        if match:
            return Path(match.group(1))
    return None


def _extract_urls_from_task(task: Dict[str, Any]) -> List[str]:
    """Extracts all URLs from task annotations."""
    urls = []
    annotations = task.get("annotations", [])
    for ann in annotations:
        description = ann.get("description", "")
        found = URL_PATTERN.findall(description)
        urls.extend(found)
    return urls


def open_path(path: Path) -> None:
    """Opens a file or directory using the default system application."""
    system = platform.system()
    try:
        if system == "Darwin":
            subprocess.run(["open", str(path)], check=True)
        elif system == "Linux":
            subprocess.run(["xdg-open", str(path)], check=True)
        elif system == "Windows":
            os.startfile(str(path))
        else:
            logging.warning(f"Unsupported OS: cannot open folder {path}")
    except subprocess.CalledProcessError as e:
        logging.error(f"Failed to open path {path}: {e}")
    except Exception as e:
        logging.error(f"Error opening path {path}: {e}")


def open_url(url: str) -> None:
    """Opens a URL using the default system browser."""
    system = platform.system()
    try:
        if system == "Darwin":
            subprocess.run(["open", url], check=True)
        elif system == "Linux":
            subprocess.run(["xdg-open", url], check=True)
        elif system == "Windows":
            os.startfile(url)
        else:
            webbrowser.open(url)
    except subprocess.CalledProcessError as e:
        logging.error(f"Failed to open URL {url}: {e}")
    except Exception as e:
        logging.error(f"Error opening URL {url}: {e}")


def create(number: str) -> None:
    """Creates a new folder for the given task and annotates it."""
    try:
        today = datetime.now().strftime("%Y%m%d")
        info = load_task_info(number)
        if not info:
            logging.error(f"Could not load task {number}")
            return

        # Check if a valid folder already exists in annotations
        existing_path = _extract_folder_from_task(info)
        if existing_path:
            if existing_path.exists():
                # Check if it's already in the TODO directory or needs moving
                if TODO_DIR in existing_path.parents or existing_path.parent == TODO_DIR:
                     logging.info(f"Task {number} already has a valid folder: {existing_path}")
                     return
                else:
                    new_path = TODO_DIR / existing_path.name
                    if not new_path.exists():
                        logging.info(f"Task {number} has folder at: {existing_path}")
                        return
            else:
                 logging.warning(f"Annotated folder {existing_path} does not exist.")

        uuid = info.get("uuid", "")
        # Use only the first part of UUID for brevity
        short_uuid = uuid.split('-')[0] if '-' in uuid else uuid
        folder_name = f"{today}-{short_uuid}"
        folder_path = TODO_DIR / folder_name

        if not folder_path.exists():
            folder_path.mkdir(parents=True, exist_ok=True)
            logging.info(f"Created folder: {folder_path}")
        else:
            logging.info(f"Folder already exists: {folder_path}")

        subprocess.run(["task", number, "annotate", str(folder_path)], check=True)
        logging.info(f"Annotated task {number} with folder path.")

    except subprocess.CalledProcessError as e:
        logging.error(f"Failed to run task command: {e}")
    except OSError as e:
        logging.error(f"Filesystem error: {e}")


def open_folder(number: str) -> None:
    """Opens the folder linked to the task."""
    info = load_task_info(number)
    if not info:
        logging.error(f"Could not load task {number}")
        return

    folder_path = _extract_folder_from_task(info)
    if folder_path and folder_path.exists():
        open_path(folder_path)
        logging.info(f"Opened folder: {folder_path}")
        return
    
    if folder_path:
        logging.warning(f"Folder path annotated but does not exist: {folder_path}")
    else:
        logging.warning(f"No folder annotation found for task {number}")


def get_folder(number: str) -> None:
    """Prints the folder path linked to the task."""
    info = load_task_info(number)
    if not info:
        logging.error(f"Could not load task {number}")
        return

    folder_path = _extract_folder_from_task(info)
    if folder_path:
        print(folder_path)
    else:
        logging.warning(f"No folder path found for task {number}")


def add_url(number: str, url: str) -> None:
    """Registers a URL as an annotation on the given task."""
    info = load_task_info(number)
    if not info:
        logging.error(f"Could not load task {number}")
        return

    if not URL_PATTERN.fullmatch(url):
        logging.error(f"Invalid URL: {url}")
        return

    # Check for duplicate
    existing_urls = _extract_urls_from_task(info)
    if url in existing_urls:
        logging.info(f"URL already registered on task {number}: {url}")
        return

    try:
        subprocess.run(["task", number, "annotate", url], check=True)
        logging.info(f"Registered URL on task {number}: {url}")
    except subprocess.CalledProcessError as e:
        logging.error(f"Failed to annotate task {number}: {e}")


def open_task_url(number: str) -> None:
    """Opens URL(s) linked to the task. Prompts for selection if multiple."""
    info = load_task_info(number)
    if not info:
        logging.error(f"Could not load task {number}")
        return

    urls = _extract_urls_from_task(info)
    if not urls:
        logging.warning(f"No URL found for task {number}")
        return

    if len(urls) == 1:
        open_url(urls[0])
        logging.info(f"Opened URL: {urls[0]}")
        return

    # Multiple URLs: prompt user to select
    print(f"\nMultiple URLs found for task {number}:")
    for i, url in enumerate(urls, start=1):
        print(f"  [{i}] {url}")
    print(f"  [0] Open all")

    try:
        choice = input("\nSelect an option: ").strip()
        if choice == "0":
            for url in urls:
                open_url(url)
                logging.info(f"Opened URL: {url}")
            return

        idx = int(choice)
        if 1 <= idx <= len(urls):
            open_url(urls[idx - 1])
            logging.info(f"Opened URL: {urls[idx - 1]}")
        else:
            logging.error(f"Invalid option: {choice}")
    except (ValueError, EOFError):
        logging.error("Invalid input.")


def archive_folder(number: str) -> None:
    """Moves the linked folder to the archive directory."""
    info = load_task_info(number)
    if not info:
        logging.error(f"Could not load task {number}")
        return

    folder_path_from = _extract_folder_from_task(info)
    if not folder_path_from:
        logging.warning(f"No folder annotation found for task {number}")
        return

    if not folder_path_from.exists():
        logging.warning(f"Folder does not exist: {folder_path_from}")
        return

    folder_name = folder_path_from.name
    folder_path_to = ARCHIVE_DIR / folder_name

    # Ensure archive directory exists
    if not ARCHIVE_DIR.exists():
        ARCHIVE_DIR.mkdir(parents=True, exist_ok=True)

    if not any(folder_path_from.iterdir()):
        try:
            folder_path_from.rmdir()
            logging.info(f"Deleted empty folder: {folder_path_from}")
        except OSError as e:
             logging.error(f"Error deleting empty folder: {e}")
        return

    try:
        folder_path_from.rename(folder_path_to)
        logging.info(f"Moved folder to archive: {folder_path_to}")
    except OSError as e:
        logging.error(f"Error moving folder: {e}")


def reopen_folder(number: str) -> None:
    """Moves the linked folder from archive back to the todo directory."""
    info = load_task_info(number)
    if not info:
        logging.error(f"Could not load task {number}")
        return

    folder_path_old = _extract_folder_from_task(info)
    if not folder_path_old:
        logging.warning(f"No folder annotation found for task {number}")
        return

    folder_name = folder_path_old.name
    folder_path_from = ARCHIVE_DIR / folder_name
    folder_path_to = TODO_DIR / folder_name

    # Ensure todo directory exists
    if not TODO_DIR.exists():
        TODO_DIR.mkdir(parents=True, exist_ok=True)

    if not folder_path_from.exists():
        logging.warning(f"Folder not found in archive: {folder_path_from}")
        return

    if folder_path_to.exists():
        logging.error(f"Folder already exists in todo: {folder_path_to}")
        return

    try:
        folder_path_from.rename(folder_path_to)
        logging.info(f"Moved folder back to todo: {folder_path_to}")
    except OSError as e:
        logging.error(f"Error moving folder: {e}")
        return

    # Rewrite annotation: remove old, add new. Move-first ordering means a
    # taskwarrior failure here leaves the filesystem correct; the user is
    # informed via the log and can re-annotate manually.
    try:
        subprocess.run(
            ["task", number, "denotate", str(folder_path_old)], check=True
        )
    except subprocess.CalledProcessError as e:
        logging.error(f"Failed to remove old annotation {folder_path_old}: {e}")

    try:
        subprocess.run(
            ["task", number, "annotate", str(folder_path_to)], check=True
        )
        logging.info(f"Reopened folder: {folder_path_to}")
    except subprocess.CalledProcessError as e:
        logging.error(f"Failed to add new annotation {folder_path_to}: {e}")


def list_folders(archived: bool = False) -> None:
    """Lists all folders in the TODO or ARCHIVE directory and their associated tasks."""
    folder_to_task: Dict[str, tuple[str, str, str]] = {}

    try:
        output = subprocess.check_output(["task", "export"], text=True)
        tasks = json.loads(output)
    except subprocess.CalledProcessError as e:
        logging.error(f"Failed to export tasks: {e}")
        return
    except json.JSONDecodeError as e:
        logging.error(f"Failed to parse task export: {e}")
        return

    for task in tasks:
        task_id = task.get("id", "?")
        uuid = task.get("uuid", "")
        description = task.get("description", "No description")
        annotations = task.get("annotations", [])
        for ann in annotations:
            match = FOLDER_PATH_PATTERN.search(ann.get("description", ""))
            if match:
                folder_path = Path(match.group(0))
                folder_name = folder_path.name
                folder_to_task[folder_name] = (str(task_id), uuid, description)

    target_dir = ARCHIVE_DIR if archived else TODO_DIR
    print(f"\nFolders in: {target_dir}")
    if not target_dir.exists():
         logging.warning(f"Directory not found: {target_dir}")
         return

    try:
        folders = sorted(
            f.name for f in target_dir.iterdir()
            if f.is_dir() and FOLDER_NAME_PATTERN.fullmatch(f.name)
        )
        if not folders:
            print("  (no folders found)")
            return

        for folder in folders:
            print(f" - {folder}")
            if folder in folder_to_task:
                task_id, uuid, desc = folder_to_task[folder]
                status_str = f"Task {task_id}" if task_id != "0" else f"UUID {uuid}"
                print(f"    → {status_str}: {desc}")
            else:
                print(f"    → (No active task found)")

    except OSError as e:
        logging.error(f"Error listing directory {target_dir}: {e}")


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Manage folders linked to Taskwarrior tasks"
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    p_create = subparsers.add_parser("create", help="Create folder for task")
    p_create.add_argument("number", type=str, help="Task ID or UUID")

    p_open = subparsers.add_parser("open", help="Open folder for task")
    p_open.add_argument("number", type=str, help="Task ID or UUID")

    p_archive = subparsers.add_parser("archive", help="Archive folder for task")
    p_archive.add_argument("number", type=str, help="Task ID or UUID")

    p_reopen = subparsers.add_parser("reopen", help="Move folder back from archive to todo")
    p_reopen.add_argument("number", type=str, help="Task ID or UUID")

    p_get = subparsers.add_parser("get", help="Get folder path for task")
    p_get.add_argument("number", type=str, help="Task ID or UUID")

    p_addurl = subparsers.add_parser("addurl", help="Register a URL on a task")
    p_addurl.add_argument("number", type=str, help="Task ID or UUID")
    p_addurl.add_argument("url", type=str, help="URL to register")

    p_openurl = subparsers.add_parser("openurl", help="Open URL(s) linked to a task")
    p_openurl.add_argument("number", type=str, help="Task ID or UUID")

    p_list = subparsers.add_parser("list", help="List all folders and linked task descriptions")
    p_list.add_argument("-a", "--archived", action="store_true", help="List archived folders instead of active ones")

    args = parser.parse_args()

    if args.command == "create":
        create(args.number)
    elif args.command == "open":
        open_folder(args.number)
    elif args.command == "archive":
        archive_folder(args.number)
    elif args.command == "reopen":
        reopen_folder(args.number)
    elif args.command == "get":
        get_folder(args.number)
    elif args.command == "addurl":
        add_url(args.number, args.url)
    elif args.command == "openurl":
        open_task_url(args.number)
    elif args.command == "list":
        list_folders(archived=args.archived)


if __name__ == "__main__":
    main()
